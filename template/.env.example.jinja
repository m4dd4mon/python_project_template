# Umgebungsvariablen und Secrets. Diese Datei ist die Vorlage; die
# tatsaechlichen Werte stehen in .env, die niemals ins Git gehoert.
{% if use_database %}
# ── Datenbank-Verbindungen ─────────────────────────────────────────
# Dieses Projekt unterstuetzt zwei parallele DB-Verbindungen. Du kannst
# beide, eine oder keine benutzen. Lass die nicht gewuenschte einfach
# leer (weglassen oder auskommentiert lassen).

# Hauptdatenbank: typischerweise eine externe Produktions- oder Firmen-DB.
# Im Entwicklungsalltag darf dies auch die lokale Docker-DB sein.
# Beispiel extern: postgresql+psycopg://user:pass@db.firma.intern:5432/{{ package_slug }}
# Beispiel lokal:  postgresql+psycopg://{{ package_slug }}:devpass@localhost:5432/{{ package_slug }}
#DATABASE_URL_MAIN=

# Zusatzdatenbank: typischerweise die lokale Docker-Instanz, z.B. fuer
# Staging-Daten, experimentelle Schemaaenderungen oder Offline-Tests.
# Wird nur benoetigt, wenn parallel zur Hauptdatenbank eine zweite
# Instanz laufen soll. Die docker-compose.yml startet mit dem Profil
# "local-db" einen passenden Postgres-Container.
#DATABASE_URL_LOCAL=postgresql+psycopg://{{ package_slug }}:devpass@localhost:5432/{{ package_slug }}
{% endif %}
