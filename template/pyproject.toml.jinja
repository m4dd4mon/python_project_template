# ── Paket-Metadaten ────────────────────────────────────────────────
[project]
name = "{{ package_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" },
]

dependencies = [
    # Konfiguration und Datenvalidierung
    "pydantic>=2.0",
    "pydantic-settings>=2.0",
    "pyyaml>=6.0",
{%- if use_database %}
    # Datenbank-Anbindung (Dual-DB-Design)
    "sqlalchemy>=2.0",
    "alembic>=1.13",
    "psycopg[binary]>=3.1",
{%- endif %}
]

[project.optional-dependencies]
dev = [
    "ruff>=0.6",
    "mypy>=1.11",
    "pytest>=8.0",
    "pytest-cov>=5.0",
]

{% if use_web or use_gui or use_cli -%}
# Entry-Points fuer die aktivierten Oberflaechen. Aufruf nach `uv sync`
# per `uv run {{ package_slug }}-<oberflaeche>`.
[project.scripts]
{% if use_web -%}
{{ package_slug }}-web = "{{ package_slug }}.web.app:main"
{% endif -%}
{% if use_gui -%}
{{ package_slug }}-gui = "{{ package_slug }}.gui.app:main"
{% endif -%}
{% if use_cli -%}
{{ package_slug }}-cli = "{{ package_slug }}.cli.main:main"
{% endif %}
{% endif -%}

# ── Build-Backend ──────────────────────────────────────────────────
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_slug }}"]


# ── ruff ───────────────────────────────────────────────────────────
[tool.ruff]
src = ["src"]
line-length = 88
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
# E/W = pycodestyle, F = pyflakes, I = isort, UP = pyupgrade
select = ["E", "W", "F", "I", "UP"]
ignore = ["E501"]   # Zeilenlaenge ueberlassen wir dem Formatter

[tool.ruff.lint.per-file-ignores]
"tests/*" = ["F401"]   # Unbenutzte Importe in Tests oft absichtlich (Fixtures)

[tool.ruff.format]
quote-style = "double"


# ── mypy ───────────────────────────────────────────────────────────
[tool.mypy]
mypy_path = "src"
packages = ["{{ package_slug }}"]
python_version = "{{ python_version }}"
warn_return_any = true
warn_unused_ignores = true
disallow_untyped_defs = true

# Bibliotheken ohne Typ-Stubs nicht anmeckern
[[tool.mypy.overrides]]
module = ["sqlalchemy.*", "alembic.*"]
ignore_missing_imports = true


# ── pytest ─────────────────────────────────────────────────────────
[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = ["--tb=short", "--strict-markers"]
markers = [
    "slow: Tests die laenger dauern, mit -m 'not slow' ueberspringen",
    "integration: Tests die echte DB oder externe Dienste brauchen",
]
